# TravelRouter environment file.
# Copy to travelrouter.env (same folder) and edit. The systemd unit loads it via
# EnvironmentFile=-/opt/travelrouter/travelrouter.env. travelrouter.env is
# gitignored, so your settings survive `git pull`.

# The data file path is set by the systemd unit (StateDirectory) to
# /var/lib/travelrouter/data.json. Uncomment to override.
#TRAVELROUTER_DATA_FILE_PATH=/var/lib/travelrouter/data.json

# Set to 1 when serving over HTTPS (e.g. behind a TLS reverse proxy) so the
# admin session cookie gets the Secure flag.
#TRAVELROUTER_AUTH_SECURE_COOKIE=0

# Admin session lifetime in seconds (default 86400 = 24h).
#TRAVELROUTER_AUTH_SESSION_TTL_SECONDS=86400

# Session cookie name (default tr_session).
#TRAVELROUTER_AUTH_COOKIE_NAME=tr_session
